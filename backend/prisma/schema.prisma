generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id        String   @id @default(uuid())
  role      String
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CadastroDbv {
  id                   String   @id @default(uuid())
  matricula            Int      @unique
  nome                 String
  idade                Int
  cpf                  String   @unique
  rg                   String   @unique
  cargo                String
  classes              String[]
  especialidades       String[]
  nomeResponsavel      String
  telefoneResponsavel  String
  rua                  String
  numero               Int
  bairro               String
  cidade               String
  estado               String
  cep                  String
  observacao           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  unidadeId            String
  unidade              Unidade  @relation(fields: [unidadeId], references: [id])
}

model Unidade {
  id         String        @id @default(uuid())
  nome       String        @unique
  pontuacao  Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  
  membros    CadastroDbv[]
}
